    "merge": "i18next-resources-for-ts merge -i public/locales/zh-CN -o ./src/@types/resources.json",
    "interface": "i18next-resources-for-ts interface -i public/locales/zh-CN -o ./src/@types/resources.d.ts",
    "i18n": "yarn toc && yarn merge && yarn interface",
    "prebuild": "yarn i18n && prisma migrate dev && prisma db push",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "update": "DIST=.next-tmp && git stash && git pull -f && yarn && DIST=$DIST yarn build && rm -rf .next && mv $DIST .next",
    "run-reset-quota-daily": "pm2 start 'npx --yes tsx scripts/reset-quota-daily.ts' --name 'reset-quota-daily' -c '0 4 * * *' --no-autorestart"
  },
