model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

////////////////////////////
// enums
///////////////////////////

enum ChatMessageFormatType {
  text
  image
  voice
  video
  map
  realtimeVoice
  realtimeVideo

  systemNotification
}

enum InvitationStatus {
  Idle
  Pending
  Accepted
  Expired
}

enum PlatformType {
  Poketto
  FlowGPT
  OpenAI
  MidJourney
  StableDiffusion
  OpenChat
}

enum PromptRoleType {
  system
  user
  assistant
  function
}

enum RoleType {
  admin
  manager
  normal
}
