// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// next-auth
// -----------------------------------------------------------------------------
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  refresh_token_expires_in Int? // github necessary

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  desc          String?

  accounts Account[]
  sessions Session[]

  invitedFrom Invitation[] @relation("from")
  invitdeTo   Invitation[] @relation("to")

  following  User[] @relation("follow")
  followedBy User[] @relation("follow")

  balance     Int              @default(0)
  usingApps   PokettoApp[]     @relation("use")
  starredApps PokettoApp[]     @relation("star")
  forkedApps  PokettoApp[]     @relation("fork")
  comments    PokettoComment[]
}

// -----------------------------------------------------------------------------
// invitation
// -----------------------------------------------------------------------------
enum InvitationStatus {
  Idle
  Pending
  Accepted
  Expired
}

model Invitation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  status    InvitationStatus @default(Idle)
  // code if necessary

  from   User   @relation("from", fields: [fromId], references: [id])
  fromId String

  to   User?   @relation("to", fields: [toId], references: [id])
  toId String? @unique
}

// -----------------------------------------------------------------------------
// poketto app
// -----------------------------------------------------------------------------
enum Platform {
  Poketto
  FlowGPT
  OpenAI
  MidJourney
  StableDiffusion
  OpenChat
}

model UniversalUser {
  id            String       @id
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  desc          String?
  PokettoApp    PokettoApp[]
}

model PokettoApp {
  id           String           @id @default(cuid())
  version      String           @default("1.0.0")
  platform     Platform
  CreatedAt    DateTime         @default(now())
  UpdatedAt    DateTime         @updatedAt
  owner        UniversalUser    @relation(references: [id], fields: [ownerId])
  ownerId      String
  users        User[]           @relation("use")
  starredUsers User[]           @relation("star")
  forkedUsers  User[]           @relation("fork")
  comments     PokettoComment[]
}

model PokettoComment {
  id           String     @id @default(cuid())
  CreatedAt    DateTime   @default(now())
  UpdatedAt    DateTime   @updatedAt
  owner        User       @relation(fields: [ownerId], references: [id])
  ownerId      String
  pokettoApp   PokettoApp @relation(fields: [pokettoAppId], references: [id])
  pokettoAppId String
}
