///////////////////////////
// ref: https://pris.ly/d/prisma-schema
///////////////////////////

generator client {
  provider = "prisma-client-js"
  // output   = "../node_modules/@prisma/client/generated" // support for webstorm autocompletion
}

generator json {
  /// Always after the prisma-client-js generator
  provider = "prisma-json-types-generator"
  namespace = "PrismaJson"
  // clientOutput = "<finds it automatically>"
  // (./ -> relative to schema, or an importable path to require() it)
  // useType = "MyType"
  // In case you need to use a type, export it inside the namespace and we will add a index signature to it
  // (e.g.  export namespace PrismaJson { export type MyType = {a: 1, b: 2} }; will generate namespace.MyType["TYPE HERE"])
}

generator zod {
  provider       = "npx zod-prisma-types"
}
// generator zod {
//   provider                         = "npx zod-prisma-types"
//
//   output                           = "../node_modules/.prisma/generated/zod" // default is ./generated/zod
//   prismaClientPath                 = "@prisma/client" // default is client output path
//
//   // 尽管开多个文件看起来很壮观，导入的时候也更小，但是在前期，有可能会一直改，所以并不方便
//   useMultipleFiles                 = false // default is false
//   writeBarrelFiles                 = false // default is true
//
//   createInputTypes                 = true // default is true // 这个只要打开，所有的就都有
//   createModelTypes                 = false // default is true // 这个只有最基本的 model
//   validateWhereUniqueInput         = true // default is false // 这个似乎无所谓
//
//   addInputTypeValidation           = false // default is true
//   addIncludeType                   = false // default is true
//   addSelectType                    = false // default is true
//   createOptionalDefaultValuesTypes = false // default is false
//   createRelationValuesTypes        = false // default is false
//   createPartialTypes               = false // default is false
//   useDefaultValidators             = false // default is true
//   coerceDate                       = false // default is true
//   writeNullishInModelTypes         = false // default is false
// }

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

