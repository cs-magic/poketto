// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // NOTE: When using mysql or sqlserver, uncomment the @db.Text annotations in model Account below
  // Further reading:
  // https://next-auth.js.org/adapters/prisma#create-the-prisma-schema
  // https://www.prisma.io/docs/reference/api-reference/prisma-schema-reference#string
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// next-auth
// -----------------------------------------------------------------------------
model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String? // @db.Text
  access_token             String? // @db.Text
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String? // @db.Text
  session_state            String?
  user                     User    @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  refresh_token_expires_in Int? // github necessary

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id       String    @id @default(cuid())
  accounts Account[]
  sessions Session[]

  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  desc          String?

  balance Int @default(0)

  invitedFrom InvitationRelation[] @relation("from")
  invitdeTo   InvitationRelation[] @relation("to")

  followedBy FollowRelation[] @relation("from")
  following  FollowRelation[] @relation("to")

  chatMessages       ChatMessage[]
  chatMessageActions ChatMessageAction[]

  user_space UserSpaceRelation[]
  tags       AppTag[]

  appComments AppComment[]
  appActions  AppAction[]
  StarringApp StarringApp[]
  createdApps App[]
}

model FollowRelation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  from   User   @relation("from", fields: [fromId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  to     User   @relation("to", fields: [toId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fromId String
  toId   String
}

model Space {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name       String
  isPrivate  Boolean             @default(true)
  user_space UserSpaceRelation[]

  UsingApp UsingApp[]
}

enum RoleType {
  admin
  manager
  normal
}

model UserSpaceRelation {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?  @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String

  space   Space  @relation(fields: [spaceId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  spaceId String

  role RoleType @default(normal)

  @@id([userId, spaceId])
}

// -----------------------------------------------------------------------------
// invitation
// -----------------------------------------------------------------------------
enum InvitationStatus {
  Idle
  Pending
  Accepted
  Expired
}

model InvitationRelation {
  id        String           @id @default(cuid())
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  status    InvitationStatus @default(Idle)
  // code if necessary

  from   User?  @relation("from", fields: [fromId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  fromId String

  to   User?   @relation("to", fields: [toId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  toId String? @unique
}

// -----------------------------------------------------------------------------
// poketto app
// -----------------------------------------------------------------------------
enum PlatformType {
  Poketto
  FlowGPT
  OpenAI
  MidJourney
  StableDiffusion
  OpenChat
}

model App {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator    User         @relation(references: [id], fields: [creatorId], onUpdate: Cascade, onDelete: Cascade)
  creatorId  String
  name       String
  avatar     String
  desc       String
  language   String       @default("en")
  version    String       @default("1.0.0")
  platform   PlatformType
  tags       AppTag[]
  category   AppCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  categoryId Int

  actions  AppAction[]
  using    UsingApp[]
  starring StarringApp[]
  comments AppComment[]

  model AppModel?
  state AppState?
}

/// use 和 star 是一个持久的、可来回变化的属性
/// 与 view 等无脑递增的还是有区别
/// 之所以独立设计model，主要是方便在 trpc 里去获取
/// 这样 app 的返回结果就始终是固定的数据结构，只需要 AppWithRelation 就可以
/// 区别就在于数据表不一样

/// space -- use --> app
model UsingApp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  appId String

  isActive Boolean @default(true)

  space   Space  @relation(fields: [spaceId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  spaceId String

  messages ChatMessage[]
}

/// user -- star --> app
model StarringApp {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  appId String

  isActive Boolean @default(true)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String
}

model AppModel {
  id        String    @id @default(cuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  // 为了减少理解成本，就不加 name 了（默认为app.title）
  type         String
  initPrompts  PrommptMessage[]
  isOpenSource Boolean          @default(true)

  app   App    @relation(fields: [appId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  appId String @unique

  temperature Float @default(0.7)
}

model AppState {
  id        String    @id @default(cuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  views  Int   @default(0)
  stars  Int   @default(0)
  forks  Int   @default(0)
  tips   Float @default(0)
  calls  Int   @default(0)
  shares Int   @default(0)

  app   App    @relation(fields: [appId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  appId String @unique
}

enum PromptRoleType {
  system
  user
  assistant
}

model PrommptMessage {
  /// or user message
  id      String         @id @default(cuid())
  role    PromptRoleType
  content String

  AppModel   AppModel? @relation(fields: [appModelId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  appModelId String?
}

enum ChatMessageFormatType {
  text
  image
  voice
  video
  map
  realtimeVoice
  realtimeVideo

  systemNotification
}

model ChatMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  userId String? // system notification

  role                PromptRoleType        @default(user)
  content             String
  format              ChatMessageFormatType @default(text)
  userActionOnMessage ChatMessageAction[]

  UsingApp   UsingApp @relation(fields: [usingAppId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  usingAppId String   @unique
}

model AppCategory {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  main String
  sub  String?
  App  App[]

  @@unique([main, sub])
}

model AppTag {
  id String @id @default(cuid())

  /// 这几个主要是 flowgpt 没有
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt
  creator   User?     @relation(fields: [creatorId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  creatorId String?

  name String
  apps App[]
}

// -----------------------------------------------------------------------------
// actions
// -----------------------------------------------------------------------------

model AppAction {
  id        String    @id @default(cuid())
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  user   User?   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId String?
  app    App     @relation(fields: [appId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  appId  String

  action String
}

model ChatMessageAction {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User        @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId    String
  message   ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  messageId String

  action String
}

model AppComment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onUpdate: Cascade, onDelete: Cascade)
  userId String
  aApp   App    @relation(fields: [appId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  appId  String

  title   String?
  content String
  rate    Int?    @default(0)
}
